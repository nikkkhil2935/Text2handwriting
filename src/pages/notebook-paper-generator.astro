---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaperApp from '../components/paper/PaperApp';
import AdSlot from '../components/common/AdSlot.astro';

const paperSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  'name': 'Online Printable Notebook Paper Generator',
  'operatingSystem': 'Any',
  'applicationCategory': 'UtilitiesApplication',
  'description': 'Generate custom ruled, grid, dot-grid, and legal notebook paper templates dynamically. Customize line color, spacing, margins, and download high-res PDFs.',
  'offers': {
    '@type': 'Offer',
    'price': '0.00',
    'priceCurrency': 'USD'
  }
};
---

<BaseLayout 
  title="Ruled Notebook Paper Generator - Free Printable Grid & Lined Sheets"
  description="Generate custom printable notebook papers online. Build lined worksheets, graph grid paper, dot-grid templates, and legal pads. Download as multi-page ZIP files."
  activeTab="home"
  showHeroGradient={true}
  fullWidth={true}
  schema={paperSchema}
>
  <div class="space-y-6">
    <AdSlot slotId="header-leaderboard" />

    <div class="max-w-4xl mx-auto text-center space-y-2 mb-4">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-primary uppercase font-mono">Ruled Notebook Paper Generator</h1>
      <p class="text-xs text-mute font-mono">Create and download printable lined paper, graph grid paper, legal pads, and dot grids.</p>
    </div>

    <PaperApp client:load />

    <!-- Rich SEO Content Section (600+ Words) -->
    <div class="max-w-4xl mx-auto py-12 px-4 border-t border-hairline space-y-8 text-body text-xs md:text-sm leading-relaxed">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-4">
          <h2 class="text-base font-semibold text-primary font-mono">Why Use an Online Paper Generator?</h2>
          <p>
            Lined notebook sheets and graph paper represent fundamental resources for student assignments, design drafts, and handwriting practice. Instead of buying physical notebooks, an online paper maker allows you to generate custom ruled paper sheets instantly.
          </p>
          <p>
            You can configure the exact grid size, line spacing, border margins, and ink color. Whether you need standard college ruled notebook paper, graph sheets for engineering equations, or dot grids for bullet journaling, our generator builds clean, pixel-perfect templates ready to print.
          </p>
        </div>

        <div class="space-y-4">
          <h2 class="text-base font-semibold text-primary font-mono">Types of Printable Paper Styles Available</h2>
          <p>
            Our tool supports several popular paper styles suited for educational and drafting tasks:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Single Ruled:</strong> Standard notebook format with horizontal ruling lines. Includes red margin options.</li>
            <li><strong>Double Ruled:</strong> Dual-line guides designed specifically for children learning cursive writing and calligraphy practice.</li>
            <li><strong>Legal Pad:</strong> Canonical yellow background paper with vertical left margins.</li>
            <li><strong>Graph Grid:</strong> Square grids suited for mathematics equations, coordinate charting, and technical sketches.</li>
            <li><strong>Dot Grid:</strong> Faint dotted patterns combining structured guidelines with minimal visual clutter. Ideal for journals.</li>
          </ul>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-base font-semibold text-primary font-mono">Standard Paper Dimensions & Print Settings</h2>
        <p>
          To print the generated papers correctly without layout cuts or sizing issues, ensure your print dimensions match the paper settings:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="border border-hairline p-4 rounded bg-canvas-soft">
            <h4 class="font-bold text-primary mb-1">A4 Standard Format</h4>
            <p class="text-xs">
              Measuring 210 x 297 mm (8.27 x 11.69 inches). Commonly used internationally for assignments, lab file sheets, and writing worksheets.
            </p>
          </div>
          <div class="border border-hairline p-4 rounded bg-canvas-soft">
            <h4 class="font-bold text-primary mb-1">Letter Size</h4>
            <p class="text-xs">
              Measuring 8.5 x 11 inches. The standard paper sizing format used across the United States, Canada, and parts of Latin America.
            </p>
          </div>
          <div class="border border-hairline p-4 rounded bg-canvas-soft">
            <h4 class="font-bold text-primary mb-1">Legal Pad Size</h4>
            <p class="text-xs">
              Measuring 8.5 x 14 inches. Longer dimensions commonly used for legal contracts, drafts, and executive pads.
            </p>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-base font-semibold text-primary font-mono">Customizing Your Lined Papers for Handwriting</h2>
        <p>
          For optimal results when writing, match your lines to your writing size:
        </p>
        <p>
          If you have large print, choose a wider grid spacing (around 30px to 40px). For micro-text or coding drafts, scale down the grid size to 15px-20px. Adjust the margin offset (left, top, right, bottom) so that when the sheets are punched or bound into folders, your handwritten text remains perfectly aligned and margins are not hidden.
        </p>
      </div>

      <div class="bg-canvas-soft-2 p-6 rounded-lg border border-hairline space-y-3">
        <h3 class="text-xs font-mono font-bold uppercase text-primary">Need Handwriting Font Preview?</h3>
        <p class="text-xs">
          Want to see how your text will look on these papers? Use our <a href="/handwriting-font-preview" class="text-link hover:underline">font preview playground</a> to inspect 15+ handwriting variants, or convert your digital text blocks directly onto these pages using the <a href="/" class="text-link hover:underline">handwriting text converter</a>.
        </p>
      </div>
    </div>

    <AdSlot slotId="footer-leaderboard" />
  </div>
</BaseLayout>
