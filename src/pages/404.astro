---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found (404) - ScribbleCraft"
  description="Sorry, the page you are looking for does not exist on ScribbleCraft. Use our navigation menu or helper links to return to the handwriting tools."
>
  <div class="max-w-md mx-auto py-16 text-center space-y-6">
    <div class="space-y-2">
      <h1 class="text-7xl font-extrabold tracking-widest text-primary font-mono select-none">404</h1>
      <p class="text-xs font-mono font-bold uppercase text-mute">Page Not Found</p>
    </div>

    <p class="text-xs md:text-sm text-body leading-relaxed">
      Oops! The page you are looking for has been moved, deleted, or never existed in the first place. You can use the links below to navigate back to our main tools.
    </p>

    <!-- Search / Direct Navigation Helpers -->
    <div class="pt-4 space-y-3">
      <h3 class="text-[10px] font-mono font-bold uppercase text-primary tracking-wider">Try one of these instead:</h3>
      <div class="grid grid-cols-2 gap-2 text-xs font-mono">
        <a href="/" class="p-3 border border-hairline rounded bg-canvas hover:bg-canvas-soft text-primary transition-colors">
          Text Converter
        </a>
        <a href="/bulk-generator" class="p-3 border border-hairline rounded bg-canvas hover:bg-canvas-soft text-primary transition-colors">
          Bulk Generator
        </a>
        <a href="/text-to-cursive" class="p-3 border border-hairline rounded bg-canvas hover:bg-canvas-soft text-primary transition-colors">
          Cursive Maker
        </a>
        <a href="/signature-generator" class="p-3 border border-hairline rounded bg-canvas hover:bg-canvas-soft text-primary transition-colors">
          Signature Designer
        </a>
      </div>
    </div>

    <div class="pt-6">
      <a
        href="/"
        class="inline-block px-6 py-2 rounded-full border border-hairline bg-primary hover:bg-canvas-soft text-on-primary hover:text-primary transition-colors font-mono text-xs font-bold uppercase tracking-wider"
      >
        Go Back Home
      </a>
    </div>
  </div>
</BaseLayout>
