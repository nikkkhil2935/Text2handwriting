---
import BaseLayout from '../layouts/BaseLayout.astro';
import FontPreviewApp from '../components/fonts/FontPreviewApp';
import AdSlot from '../components/common/AdSlot.astro';
import RelatedTools from '../components/common/RelatedTools.astro';

const FONT_FAQS = [
  {
    q: 'What are the best handwriting fonts for assignments?',
    a: 'For school assignments, we recommend Architects Daughter for clean legibility, Kalam for a neat Indian handwriting style, and Patrick Hand for a natural rounded look. These fonts are highly readable and match classical notebook aesthetics.'
  },
  {
    q: 'Can I preview handwriting fonts with my own custom text?',
    a: 'Yes! The font preview tool lets you type any text and renders it across all 20+ handwriting fonts simultaneously. You can compare styles side by side and find the one that matches your preferred neatness, slant, and flow.'
  },
  {
    q: 'What is the difference between cursive and print handwriting fonts?',
    a: 'Print fonts produce separate, legible letters ideal for school assignments. Cursive fonts create flowing, connected script better suited for letters, invitations, and signatures. The font preview page lets you compare both styles side by side.'
  },
  {
    q: 'Are the handwriting fonts free to use?',
    a: 'Yes! All 20+ handwriting fonts on the platform are completely free. They are self-hosted for instant loading and can be used with any of the handwriting tools including the converter, assignment formatter, and bulk generator.'
  },
  {
    q: 'How do I make digital handwriting fonts look realistic?',
    a: 'Add slant jitter of plus or minus 2 degrees, vary line heights slightly, use a lined notebook background, and enable the smudge overlay for pencil dust effects. These tweaks bypass automated checks and make output look authentically handwritten.'
  }
];

const fontsSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  'name': 'Online Handwriting Font Previewer',
  'operatingSystem': 'Any',
  'applicationCategory': 'UtilitiesApplication',
  'description': 'Preview and compare 20+ realistic handwriting fonts side-by-side. Enter your own text phrases and adjust font dimensions instantly.',
  'offers': {
    '@type': 'Offer',
    'price': '0.00',
    'priceCurrency': 'USD'
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': FONT_FAQS.map(faq => ({
    '@type': 'Question',
    'name': faq.q,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.a
    }
  }))
};

const pageSchema = {
  '@graph': [fontsSchema, faqSchema]
};
---

<BaseLayout 
  title="Handwriting Font Preview - Text to Handwriting"
  description="Preview and compare 20+ handwriting fonts side-by-side. Test cursive, neat print, and signature styles with your custom text. Free online tool."
  activeTab="font-preview"
  showHeroGradient={true}
  fullWidth={true}
  schema={pageSchema}
>
  <div class="space-y-6">
    <AdSlot slotId="header-leaderboard" />

    <div class="max-w-4xl mx-auto text-center space-y-2 mb-4">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-primary uppercase font-mono">Handwriting Font Preview Catalog</h1>
      <p class="text-xs text-mute font-mono">Test and compare all 20+ cursive, neat print, kids, and signature fonts side-by-side.</p>
    </div>

    <FontPreviewApp client:load />

    <!-- Rich SEO Content Section -->
    <div class="max-w-4xl mx-auto py-12 px-4 border-t border-hairline space-y-8 text-body text-xs md:text-sm leading-relaxed">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-4">
          <h2 class="text-base font-semibold text-primary font-mono">Best Handwriting Fonts for Notes and Assignments</h2>
          <p>
            When converting typed text to handwriting, the font choice determines the credibility of the output. If you are submitting school assignments or sending personalized letters, using a standard font library makes the page look artificial.
          </p>
          <p>
            Our <strong>handwriting font generator preview</strong> tool is designed to help you analyze and choose the perfect script variant. By rendering a single test sentence across 20+ different fonts simultaneously, you can find the style that matches your preferred neatness, slant, and flow.
          </p>
        </div>

        <div class="space-y-4">
          <h2 class="text-base font-semibold text-primary font-mono">Preview Handwriting Fonts with Custom Text</h2>
          <p>
            To help you navigate, we classify our handwriting catalog into distinct categories:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Neat & Clean:</strong> Fonts like <em>Architects Daughter</em> and <em>Patrick Hand</em>. Highly legible, well-aligned, and ideal for formal academic assignments.</li>
            <li><strong>Cursive & Script:</strong> Styles like <em>Dancing Script</em> and <em>Pacifico</em>. Elegant, continuous characters that imitate cursive fountain pens.</li>
            <li><strong>Messy & Jotted:</strong> Fonts like <em>Reenie Beanie</em> and <em>Nothing You Could Do</em>. Simulates quick jotting, diary notes, and study logs.</li>
            <li><strong>Flowing Signatures:</strong> Scripts like <em>Alex Brush</em> and <em>Mr De Haviland</em>, designed to create signature initials.</li>
          </ul>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-base font-semibold text-primary font-mono">Realistic Handwriting Font Samples Online</h2>
        <p>
          Selecting a good font is only the first step. To bypass automated check algorithms and make your homework printouts look fully authentic:
        </p>
        <ol class="list-decimal pl-5 space-y-1.5">
          <li><strong>Add Slant Jitter:</strong> Ensure you adjust the letter rotation slant slightly (plus or minus 2 degrees). Humans do not write on perfectly straight guidelines.</li>
          <li><strong>Vary Line Heights:</strong> Change line spacings to be slightly loose or tight. Tight lines make messy fonts look more compressed and organic.</li>
          <li><strong>Use Lined Notebook Backgrounds:</strong> Placing text on ruled notebook guidelines makes character alignments look natural. Ensure you align your font size to match the line heights.</li>
          <li><strong>Enable Graphite Smudge Overlays:</strong> Smudge layers add very faint background pencil dust which prints beautifully on real paper.</li>
        </ol>
      </div>

      <div class="space-y-4">
        <h2 class="text-base font-semibold text-primary font-mono">Compare Cursive vs Print Handwriting Fonts</h2>
        <p>
          The preview tool lets you type your exact assignment text and see it rendered in every font category. For a deeper dive into which style works best for your use case, read our blog post on <a href="/blog" class="text-link hover:underline">handwriting font styles</a>. Once you have picked your font, convert your text using the <a href="/" class="text-link hover:underline">text to handwriting converter</a> or format a complete assignment with the <a href="/assignment-formatter" class="text-link hover:underline">assignment formatter</a>.
        </p>
        <p>
          For cursive-specific output, try the <a href="/text-to-cursive" class="text-link hover:underline">text to cursive converter</a>. Generate personalized signatures with the <a href="/signature-generator" class="text-link hover:underline">signature generator</a>.
        </p>
      </div>

      <!-- FAQ Accordions -->
      <div class="pt-8 border-t border-hairline space-y-6">
        <h2 class="text-lg font-bold tracking-tight text-primary uppercase font-mono text-center">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {FONT_FAQS.map(faq => (
            <details class="group border border-hairline bg-canvas rounded-lg transition-all [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex justify-between items-center font-mono font-semibold text-xs text-primary p-4 cursor-pointer select-none">
                <span>{faq.q}</span>
                <span class="text-mute group-open:rotate-180 transition-transform font-bold text-xs leading-none">↓</span>
              </summary>
              <div class="px-4 pb-4 pt-0 text-xs text-body leading-relaxed border-t border-hairline/50 mt-1 pt-2">
                <p>{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>

    </div>

    <RelatedTools current="/handwriting-font-preview" />

    <AdSlot slotId="footer-leaderboard" />
  </div>
</BaseLayout>
