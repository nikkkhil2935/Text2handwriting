---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/common/AdSlot.astro';
import { FAQS } from '../data/faq';

const faqPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': FAQS.map(faq => ({
    '@type': 'Question',
    'name': faq.q,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.a
    }
  }))
};
---

<BaseLayout
  title="Help & FAQ Hub - Text to Handwriting"
  description="Find answers to frequently asked questions about converting text to handwriting, custom PDF exports, bulk queue processing, and electronic signatures."
  activeTab="faq"
  schema={faqPageSchema}
>
  <div class="max-w-3xl mx-auto space-y-8">
    <AdSlot slotId="header-leaderboard" />

    <div class="border-b border-hairline pb-4 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-primary uppercase font-mono">Frequently Asked Questions</h1>
      <p class="text-xs text-mute font-mono mt-1">Everything you need to know about the Text to Handwriting platform.</p>
    </div>

    <!-- FAQ Accordions -->
    <div class="space-y-4 pt-4">
      {FAQS.map(faq => (
        <details class="group border border-hairline bg-canvas rounded-lg transition-all [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex justify-between items-center font-mono font-semibold text-xs md:text-sm text-primary p-5 cursor-pointer select-none">
            <span>{faq.q}</span>
            <span class="text-mute group-open:rotate-180 transition-transform font-bold text-base leading-none">↓</span>
          </summary>
          <div class="px-5 pb-5 pt-0 text-xs md:text-sm text-body leading-relaxed border-t border-hairline/50 mt-1 pt-3">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="bg-canvas-soft p-6 rounded-lg border border-hairline space-y-3 mt-8">
      <h3 class="text-xs font-mono font-bold uppercase text-primary">Still have questions?</h3>
      <p class="text-xs text-body leading-relaxed">
        If you have questions that aren't answered above, feel free to visit our <a href="/about-us" class="text-link hover:underline">About Us</a> page or drop us a line directly through the <a href="/contact-us" class="text-link hover:underline">Contact Us</a> form. We're here to help!
      </p>
    </div>

    <AdSlot slotId="footer-leaderboard" />
  </div>
</BaseLayout>
