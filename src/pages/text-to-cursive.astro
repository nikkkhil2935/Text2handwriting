---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConverterApp from '../components/converter/ConverterApp';
import AdSlot from '../components/common/AdSlot.astro';

const cursiveSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  'name': 'Text to Cursive Handwriting Generator',
  'operatingSystem': 'Any',
  'applicationCategory': 'EducationalApplication',
  'description': 'Convert standard text into beautiful, flowing cursive handwriting. Choose from elegant script styles, adjust margins, and export as high-res PDF or image files.',
  'offers': {
    '@type': 'Offer',
    'price': '0.00',
    'priceCurrency': 'USD'
  }
};
---

<BaseLayout 
  title="Text to Cursive Converter - Realistic Cursive Writing Maker"
  description="Convert your typed text into elegant, realistic cursive handwriting online. Select premium script fonts, adjust ink colors, line slants, and export printable PDFs."
  activeTab="home"
  showHeroGradient={true}
  fullWidth={true}
  schema={cursiveSchema}
>
  <div class="space-y-6">
    <AdSlot slotId="header-leaderboard" />

    <ConverterApp client:load defaultFont="Dancing Script" defaultPaper="plain" />

    <!-- Rich SEO Content Section (600+ Words) -->
    <div class="max-w-4xl mx-auto py-12 px-4 border-t border-hairline space-y-8 text-body text-xs md:text-sm leading-relaxed">
      <h1 class="text-2xl font-bold tracking-tight text-primary uppercase font-mono text-center">Text to Cursive Writing Generator</h1>
      
      <p class="text-center font-mono text-mute text-xs">Transform digital text blocks into elegant handwritten scripts for personal letters, journals, and assignments.</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
        <div class="space-y-4">
          <h2 class="text-base font-semibold text-primary font-mono">Why Convert Text to Cursive Handwriting Online?</h2>
          <p>
            Cursive writing carries a timeless elegance and personal touch that standard block print simply cannot match. Whether you are crafting a heartfelt wedding invitation, writing an entries journal, or completing a history assignment, cursive fonts like <em>Dancing Script</em>, <em>Sacramento</em>, or <em>Yellowtail</em> add organic sophistication.
          </p>
          <p>
            Our online cursive handwriting generator bridges the gap between typing efficiency and handwritten realism. Instead of spending hours transcription documents manually, you can paste your content directly into our editor and render realistic cursive pages in seconds.
          </p>
        </div>

        <div class="space-y-4">
          <h2 class="text-base font-semibold text-primary font-mono">Key Features of Cursive Generator</h2>
          <p>
            Standard digital fonts look artificial because every letter is identical. Our platform solves this using a custom **Realism Engine** that introduces microscopic human errors:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Letter Connection Ligatures:</strong> Pull characters together naturally with negative letter spacing.</li>
            <li><strong>Ink Bleed Simulation:</strong> Fountain pen preset introduces ink dispersion and pressure variation.</li>
            <li><strong>Slant Control:</strong> Tilt the writing angle to mimic natural handwriting slants (from -15 to +15 degrees).</li>
            <li><strong>Continuous Page Breaking:</strong> Create multi-page cursive files with headers and footers automatically.</li>
          </ul>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-base font-semibold text-primary font-mono">Steps to Create Realistic Cursive Handwriting PDFs</h2>
        <p>
          To generate highly realistic cursive letters or assignments, follow this simple workflow:
        </p>
        <ol class="list-decimal pl-5 space-y-1.5">
          <li><strong>Input Text:</strong> Type or paste your paragraphs into the editor. You can insert page breaks using the <code>---page break---</code> marker to control page divisions.</li>
          <li><strong>Select a Cursive Font:</strong> Navigate to the Typography panel and choose a script font family like <em>Dancing Script</em>, <em>Sacramento</em>, or <em>Great Vibes</em>.</li>
          <li><strong>Adjust Paper Style:</strong> Select either plain paper, single-ruled, or custom paper images for your cursive note background.</li>
          <li><strong>Configure Realism:</strong> Turn up the messiness multiplier slightly (around 0.8x) to add character rotations, vertical baseline jitters, and graphite smudges.</li>
          <li><strong>Export:</strong> Download your finished sheets as transparent PNG images or combine them into a single print-quality 300dpi PDF document.</li>
        </ol>
      </div>

      <div class="bg-canvas-soft-2 p-6 rounded-lg border border-hairline space-y-3">
        <h3 class="text-xs font-mono font-bold uppercase text-primary">Explore Our Other Writing Tools</h3>
        <p class="text-xs">
          Need different handwriting styles? Try our <a href="/" class="text-link hover:underline">main text-to-handwriting converter</a> with 20+ neat printing fonts, compile large batches using the <a href="/bulk-generator" class="text-link hover:underline">bulk handwriting generator</a>, design signatures with our <a href="/signature-generator" class="text-link hover:underline">signature generator</a>, or download blank sheets from the <a href="/notebook-paper-generator" class="text-link hover:underline">ruled notebook paper maker</a>.
        </p>
      </div>
    </div>

    <AdSlot slotId="footer-leaderboard" />
  </div>
</BaseLayout>
