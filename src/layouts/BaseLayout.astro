---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  schema?: Record<string, any>;
  showHeroGradient?: boolean;
  activeTab?: string;
  fullWidth?: boolean;
}

const siteUrl = 'https://texttohandwriting.me';
const cleanPath = Astro.url.pathname.replace(/\/+$/, '');
const finalCanonicalUrl = Astro.props.canonicalUrl || (cleanPath === '' ? `${siteUrl}/` : `${siteUrl}${cleanPath}`);

const {
  title,
  description,
  canonicalUrl = finalCanonicalUrl,
  ogImage = '/og-image.png',
  ogType = 'website',
  schema,
  showHeroGradient = false,
  activeTab = '',
  fullWidth = false
} = Astro.props;

// Build breadcrumb list schema automatically
const urlPaths = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = urlPaths.map((path, idx) => ({
  '@type': 'ListItem',
  'position': idx + 1,
  'name': path.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
  'item': `${siteUrl}/${urlPaths.slice(0, idx + 1).join('/')}`
}));

const breadcrumbSchema = urlPaths.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': breadcrumbItems
} : null;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TEY89MX99W"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-TEY89MX99W');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="TextConvert" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="msvalidate.01" content="535FF23B7A4B19C33E26225541987ADC" />

    <!-- Google Fonts Preconnect and Prefetch -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono&display=swap" rel="stylesheet" />

    <!-- Primary SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, siteUrl)} />

    <!-- Structured Data (JSON-LD) -->
    {schema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    )}
    {breadcrumbSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    )}

    <!-- Inline script to handle theme immediately to prevent flashing -->
    <script is:inline>
      (function() {
        document.documentElement.classList.remove('dark');
      })();
    </script>
  </head>
  <body class="relative flex flex-col min-h-screen bg-canvas-soft text-ink font-sans selection:bg-primary selection:text-on-primary antialiased">
    
    <!-- Background Gradient (Vercel-like) -->
    {showHeroGradient && (
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[1400px] h-[550px] overflow-hidden pointer-events-none z-0 opacity-40 dark:opacity-20 transition-opacity">
        <div class="absolute top-[-10%] left-[-10%] w-[120%] h-[120%] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-300 via-violet-300 to-transparent blur-[120px] dark:from-blue-900 dark:via-purple-900"></div>
      </div>
    )}

    <!-- Navigation Header -->
    <header class="sticky top-0 z-40 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline py-4 px-6 md:px-12 flex items-center justify-between transition-colors">
      <div class="flex items-center space-x-8">
        <a href="/" class="flex items-center space-x-2 text-primary hover:opacity-90 font-mono tracking-tighter font-semibold text-lg">
          <span class="w-3.5 h-3.5 bg-current transform rotate-45 mr-1"></span>
          <span>Text to Handwriting</span>
        </a>
        <nav class="hidden lg:flex items-center space-x-1 text-sm font-medium">
          <a href="/" class={`px-3 py-1.5 rounded-full transition-colors ${activeTab === 'home' ? 'text-primary bg-canvas-soft-2 font-semibold' : 'text-body hover:text-primary hover:bg-canvas-soft-2/50'}`}>Text Converter</a>
          <a href="/bulk-generator" class={`px-3 py-1.5 rounded-full transition-colors ${activeTab === 'bulk' ? 'text-primary bg-canvas-soft-2 font-semibold' : 'text-body hover:text-primary hover:bg-canvas-soft-2/50'}`}>Bulk Generator</a>
          <a href="/assignment-formatter" class={`px-3 py-1.5 rounded-full transition-colors ${activeTab === 'assignment' ? 'text-primary bg-canvas-soft-2 font-semibold' : 'text-body hover:text-primary hover:bg-canvas-soft-2/50'}`}>Assignment Maker</a>
          <a href="/signature-generator" class={`px-3 py-1.5 rounded-full transition-colors ${activeTab === 'signature' ? 'text-primary bg-canvas-soft-2 font-semibold' : 'text-body hover:text-primary hover:bg-canvas-soft-2/50'}`}>Signature Maker</a>
          <a href="/notebook-paper-generator" class={`px-3 py-1.5 rounded-full transition-colors ${activeTab === 'notebook' ? 'text-primary bg-canvas-soft-2 font-semibold' : 'text-body hover:text-primary hover:bg-canvas-soft-2/50'}`}>Notebook Paper</a>
          <a href="/text-to-cursive" class={`px-3 py-1.5 rounded-full transition-colors ${activeTab === 'cursive' ? 'text-primary bg-canvas-soft-2 font-semibold' : 'text-body hover:text-primary hover:bg-canvas-soft-2/50'}`}>Cursive Converter</a>
          <a href="/handwriting-font-preview" class={`px-3 py-1.5 rounded-full transition-colors ${activeTab === 'font-preview' ? 'text-primary bg-canvas-soft-2 font-semibold' : 'text-body hover:text-primary hover:bg-canvas-soft-2/50'}`}>Font Showcase Preview</a>
        </nav>
      </div>
      
      <div class="flex items-center space-x-4">
        <!-- Dark/Light Mode Toggle (Hidden for v1) -->
        <button id="theme-toggle" class="hidden p-2 rounded-full border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-primary cursor-pointer transition-colors shadow-sm" aria-label="Toggle dark mode">
          <!-- Light Mode Icon (Sun) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block dark:hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          <!-- Dark Mode Icon (Moon) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden dark:block"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>

        <!-- Mobile Menu Trigger -->
        <button id="mobile-menu-toggle" class="lg:hidden p-2 rounded-full border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-primary cursor-pointer transition-colors" aria-label="Open navigation menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
      </div>
    </header>

    <!-- Mobile Drawer Overlay Menu -->
    <div id="mobile-menu" class="fixed inset-0 z-50 bg-canvas-soft/95 backdrop-blur-md translate-x-full transition-transform duration-300 flex flex-col p-8 lg:hidden">
      <div class="flex items-center justify-between mb-8">
        <span class="font-mono font-semibold tracking-tighter text-lg text-primary flex items-center">
          <span class="w-3.5 h-3.5 bg-current transform rotate-45 mr-2"></span>
          Text to Handwriting
        </span>
        <button id="mobile-menu-close" class="p-2 rounded-full border border-hairline bg-canvas hover:bg-canvas-soft text-body cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <nav class="flex flex-col space-y-2 text-sm font-mono mb-8 overflow-y-auto max-h-[60vh]">
        <a href="/" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Text Converter</a>
        <a href="/bulk-generator" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Bulk Generator</a>
        <a href="/assignment-formatter" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Assignment Maker</a>
        <a href="/signature-generator" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Signature Maker</a>
        <a href="/notebook-paper-generator" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Notebook Paper</a>
        <a href="/handwriting-font-preview" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Font Preview</a>
        <a href="/text-to-cursive" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Cursive Converter</a>
        <a href="/assignment-formatter" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Assignment Formatter</a>
        <a href="/faq" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">FAQ</a>
        <a href="/blog" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Blog</a>
        <a href="/about-us" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">About Us</a>
        <a href="/contact-us" class="py-2 border-b border-hairline text-primary hover:pl-2 transition-all">Contact Us</a>
      </nav>
      <div class="mt-auto pt-6 border-t border-hairline text-center">
        <p class="text-xs text-mute font-mono">texttohandwriting.me</p>
      </div>
    </div>

    <!-- Main Content Slot -->
    <main class={`relative flex-grow z-10 w-full ${fullWidth ? 'max-w-full px-4 md:px-8' : 'max-w-[1400px] mx-auto px-6 md:px-12'} py-8 transition-all`}>
      <slot />
    </main>

    <!-- Footer Area -->
    <footer class="relative z-10 w-full bg-canvas border-t border-hairline py-12 px-6 md:px-12 mt-auto transition-colors">
      <div class="max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="space-y-4">
          <span class="font-mono font-bold tracking-tighter text-primary flex items-center">
            <span class="w-3.5 h-3.5 bg-current transform rotate-45 mr-2"></span>
            Text to Handwriting
          </span>
          <p class="text-xs text-body leading-relaxed">
            The premium text-to-handwriting platform. Generate highly realistic handwritten notes, custom signatures, school assignments, and printable notebook papers dynamically with our OffscreenCanvas worker engine.
          </p>
          <p class="text-xs text-mute font-mono">
            © {new Date().getFullYear()} texttohandwriting.me
          </p>
        </div>
        <div>
          <h4 class="text-xs font-mono uppercase font-semibold text-primary mb-4 tracking-wider">Features</h4>
          <ul class="space-y-2 text-xs font-medium text-body">
            <li><a href="/" class="hover:text-primary transition-colors">Single Text Converter</a></li>
            <li><a href="/bulk-generator" class="hover:text-primary transition-colors">Bulk Handwriting Maker</a></li>
            <li><a href="/assignment-formatter" class="hover:text-primary transition-colors">Assignment Maker</a></li>
            <li><a href="/signature-generator" class="hover:text-primary transition-colors">Signature Generator</a></li>
            <li><a href="/notebook-paper-generator" class="hover:text-primary transition-colors">Notebook Paper Maker</a></li>
            <li><a href="/handwriting-font-preview" class="hover:text-primary transition-colors">Font Showcase Preview</a></li>
            <li><a href="/text-to-cursive" class="hover:text-primary transition-colors">Cursive Converter</a></li>
            <li><a href="/assignment-formatter" class="hover:text-primary transition-colors">Assignment Formatter</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-mono uppercase font-semibold text-primary mb-4 tracking-wider">Info & Support</h4>
          <ul class="space-y-2 text-xs font-medium text-body">
            <li><a href="/faq" class="hover:text-primary transition-colors">Help & FAQ Hub</a></li>
            <li><a href="/about-us" class="hover:text-primary transition-colors">About Text to Handwriting</a></li>
            <li><a href="/contact-us" class="hover:text-primary transition-colors">Contact Support</a></li>
            <li><a href="/blog" class="hover:text-primary transition-colors">Writing Blog & Guides</a></li>
            <li><span class="text-mute font-mono text-[10px]">DPI: 300 (Print Quality)</span></li>
            <li><span class="text-mute font-mono text-[10px]">Processing: Client-side</span></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-mono uppercase font-semibold text-primary mb-4 tracking-wider">Legal & Map</h4>
          <ul class="space-y-2 text-xs font-medium text-body">
            <li><a href="/privacy-policy" class="hover:text-primary transition-colors">Privacy Policy</a></li>
            <li><a href="/terms-and-conditions" class="hover:text-primary transition-colors">Terms & Conditions</a></li>
            <li>
              <div class="flex space-x-2 font-mono text-[10px] mt-2 pt-2 border-t border-hairline">
                <a href="/sitemap.xml" class="text-mute hover:text-primary">sitemap.xml</a>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle and Navigation Scripts -->
    <script is:inline>
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }

      // Mobile Menu
      const mobileToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileClose = document.getElementById('mobile-menu-close');

      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener('click', () => {
          mobileMenu.classList.remove('translate-x-full');
        });
      }
      if (mobileClose && mobileMenu) {
        mobileClose.addEventListener('click', () => {
          mobileMenu.classList.add('translate-x-full');
        });
      }

      // Close menu when clicking links
      const mobileLinks = mobileMenu?.querySelectorAll('a');
      mobileLinks?.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('translate-x-full');
        });
      });
    </script>
  </body>
</html>
